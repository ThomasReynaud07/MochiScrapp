# ========================================
# BINANCE API KEYS (REQUIS)
# ========================================
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ========================================
# PARAMÈTRES DE TRADING
# ========================================
# Paire à trader (ex: BTCUSDT, ETHUSDT, SOLUSDT)
SYMBOL=BTCUSDT

# Intervalle de bougie (1m, 5m, 15m, 1h, 4h, 1d)
INTERVAL=15m

# Montant en USDT par trade
TRADE_AMOUNT_USDT=20

# ========================================
# GESTION DU RISQUE
# ========================================
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0

# ========================================
# STRATÉGIE - Paramètres RSI
# ========================================
RSI_PERIOD=14
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65

# ========================================
# STRATÉGIE - Paramètres EMA
# ========================================
EMA_FAST=9
EMA_SLOW=21

# ========================================
# TELEGRAM BOT (OPTIONNEL)
# ========================================
# Pour recevoir les notifications:
# 1. Crée un bot via @BotFather sur Telegram
# 2. Copie le token ici
# 3. Envoie /start au bot pour obtenir le chat_id
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ========================================
# API REST (OPTIONNEL)
# ========================================
API_HOST=0.0.0.0
API_PORT=5000

# ========================================
# DISCORD WEBHOOKS (OPTIONNEL - v2.1.0)
# ========================================
# Pour créer un webhook Discord:
# 1. Aller dans les paramètres du serveur Discord
# 2. Intégrations > Webhooks > Créer un webhook
# 3. Copier l'URL ici
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ========================================
# DASHBOARD WEB (OPTIONNEL - v2.1.0)
# ========================================
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# ========================================
# RISK MANAGEMENT AVANCÉ (OPTIONNEL - v2.1.0)
# ========================================
# Position sizing dynamique (Kelly Criterion)
KELLY_FRACTION=0.25

# Limites de risque
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=20.0

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=INFO
LOG_FILE=trading_bot.log
